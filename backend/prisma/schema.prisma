// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int         @id @default(autoincrement())
  name          String
  email         String      @unique
  passwordHash  String
  role          String      @default("Employee") // Admin | Employee
  departmentId  Int?
  department    Department? @relation("DepartmentEmployees", fields: [departmentId], references: [id])
  xpTotal       Int         @default(0)
  pointsBalance Int         @default(0)
  status        String      @default("Active") // Active | Inactive
  createdAt     DateTime    @default(now())

  headOfDepartments Department[] @relation("DepartmentHead")
  departments       Department[]
}

model Department {
  id                 Int    @id @default(autoincrement())
  name               String
  code               String @unique
  headUserId         Int?
  head               User?  @relation("DepartmentHead", fields: [headUserId], references: [id])
  parentDepartmentId Int?
  employeeCount      Int    @default(0)
  status             String @default("Active") // Active | Inactive

  employees User[] @relation("DepartmentEmployees")
  user      User?  @relation(fields: [userId], references: [id])
  userId    Int?
}
